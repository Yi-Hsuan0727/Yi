        "http://localhost:3000/lawfare.html",
        "http://localhost:3000/agsec.html",
        "http://localhost:3000/lt.html",
        "http://localhost:3000/quickbite.html",
        "http://localhost:3000/magnate.html",
        "http://localhost:3000/spring.html",
        "http://localhost:3000/dailymoo.html",
        "http://localhost:3000/enchanter.html",
        "http://localhost:3000/stiffy.html",
        "http://localhost:3000/tnaf.html",
        "http://localhost:3000/whatnow.html"
