{
  "name": "yi-portfolio-ds",
  "version": "1.0.0",
  "description": "Yi-Hsuan's portfolio design system — the React component library behind the portfolio site.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.es.js",
  "module": "./dist/index.es.js",
